<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Configuração simplificada para testes -->
    <statusListener class="ch.qos.logback.core.status.NopStatusListener" />

    <!-- Propriedades -->
    <property name="APP_NAME" value="test-${spring.application.name:-app}" />

    <!-- Console Appender com saída reduzida -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%thread] %cyan(%logger{36}) - %msg%n</pattern>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
    </appender>

    <!-- Appender específico para logs de erro - mais verboso para diagnóstico -->
    <appender name="ERROR_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%thread] %cyan(%logger{36}) - %msg%n%ex{full}%n</pattern>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
    </appender>

    <!-- Configuração específica para testes -->
    <logger name="com.carrefourbank" level="DEBUG" />
    <logger name="org.springframework" level="WARN" />
    <logger name="org.hibernate" level="WARN" />
    <logger name="org.springframework.test" level="INFO" />
    <logger name="org.springframework.jdbc.core" level="WARN" />

    <!-- Silenciar logs desnecessários durante testes -->
    <logger name="org.testcontainers" level="INFO" />
    <logger name="com.github.dockerjava" level="WARN" />
    <logger name="org.hibernate.validator" level="WARN" />
    <logger name="org.apache.http" level="WARN" />

    <!-- Root logger - nível padrão para todos os logs não configurados acima -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="ERROR_CONSOLE" />
    </root>
</configuration>