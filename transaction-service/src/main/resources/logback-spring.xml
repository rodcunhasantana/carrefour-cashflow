<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Propriedades que podem ser usadas no arquivo de configuração -->
    <property name="LOG_PATH" value="${LOG_PATH:-./logs}" />
    <property name="LOG_FILE" value="${LOG_FILE:-transaction-service}" />

    <!-- Incluir informações da aplicação e ambiente -->
    <property name="APP_NAME" value="${spring.application.name:-transaction-service}" />
    <property name="PROFILE" value="${spring.profiles.active:-unknown}" />

    <!-- Adicionar conveniência para o Janino (para filtros condicionais) -->
    <if condition='isDefined("spring.application.name")'>
        <then>
            <property name="APP_NAME" value="${spring.application.name}" />
        </then>
    </if>

    <!-- Padrão para console com cores -->
    <appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [${APP_NAME},%X{traceId:-},%X{spanId:-},%X{transactionId:-}] [%thread] %cyan(%logger{36}) - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Padrão para arquivo de log geral -->
    <appender name="File" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE}.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [${APP_NAME},%X{traceId:-},%X{spanId:-},%X{transactionId:-}] [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/archived/${LOG_FILE}-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>3GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- Arquivo de log específico para transações -->
    <appender name="TransactionLogFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/transactions.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%X{transactionId:-}] %msg%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/archived/transactions-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>90</maxHistory>
            <totalSizeCap>5GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- Configuração de Log para produção -->
    <springProfile name="prod">
        <root level="WARN">
            <appender-ref ref="Console" />
            <appender-ref ref="File" />
        </root>
    </springProfile>

    <!-- Configuração para ambientes não-prod -->
    <springProfile name="!prod">
        <!-- Ajustes específicos para debug -->
        <logger name="org.springframework.jdbc" level="INFO" />
        <logger name="com.carrefourbank" level="DEBUG" />
    </springProfile>

    <!-- Logger específico para transações -->
    <logger name="com.carrefourbank.transaction.infrastructure.logging.TransactionLogger" level="INFO" additivity="false">
        <appender-ref ref="TransactionLogFile" />
        <appender-ref ref="Console" />
    </logger>

    <!-- Nível de log padrão -->
    <root level="INFO">
        <appender-ref ref="Console" />
        <appender-ref ref="File" />
    </root>
</configuration>