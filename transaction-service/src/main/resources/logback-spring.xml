<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property name="LOG_PATH" value="${LOG_PATH:-./logs}" />
    <property name="LOG_FILE" value="${LOG_FILE:-transaction-service}" />
    <property name="APP_NAME" value="${spring.application.name:-transaction-service}" />

    <!-- Console: sempre ativo -->
    <appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [${APP_NAME},%X{traceId:-},%X{spanId:-},%X{transactionId:-}] [%thread] %cyan(%logger{36}) - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- File appenders: apenas em produção (onde /app/logs existe e tem permissão) -->
    <springProfile name="prod">
        <appender name="File" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH}/${LOG_FILE}.log</file>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [${APP_NAME},%X{traceId:-},%X{spanId:-},%X{transactionId:-}] [%thread] %logger{36} - %msg%n</pattern>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH}/archived/${LOG_FILE}-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>10MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>3GB</totalSizeCap>
            </rollingPolicy>
        </appender>

        <appender name="TransactionLogFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH}/transactions.log</file>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%X{transactionId:-}] %msg%n</pattern>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH}/archived/transactions-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>10MB</maxFileSize>
                <maxHistory>90</maxHistory>
                <totalSizeCap>5GB</totalSizeCap>
            </rollingPolicy>
        </appender>

        <logger name="com.carrefourbank.transaction.infrastructure.logging.TransactionLogger" level="INFO" additivity="false">
            <appender-ref ref="TransactionLogFile" />
            <appender-ref ref="Console" />
        </logger>

        <root level="WARN">
            <appender-ref ref="Console" />
            <appender-ref ref="File" />
        </root>
    </springProfile>

    <!-- dev / default: apenas console -->
    <springProfile name="!prod">
        <logger name="org.springframework.jdbc" level="INFO" />
        <logger name="com.carrefourbank" level="DEBUG" />
        <logger name="com.carrefourbank.transaction.infrastructure.logging.TransactionLogger" level="INFO" additivity="false">
            <appender-ref ref="Console" />
        </logger>

        <root level="INFO">
            <appender-ref ref="Console" />
        </root>
    </springProfile>
</configuration>
